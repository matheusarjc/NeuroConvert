# Copie para `.env.local` e preencha (ver também context.md).

# Claude (Anthropic)
ANTHROPIC_API_KEY=
# Opcional — default: claude-sonnet-4-20250514
ANTHROPIC_MODEL=

# Firecrawl
FIRECRAWL_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# ID do preço mensal Pro (Dashboard → Produtos → Preço → copiar "API ID", ex.: price_1ABC...)
STRIPE_PRICE_PRO=
# Opcional: só se criares preço self-serve Agência no Stripe; o checkout da app aceita apenas Pro.
# STRIPE_PRICE_AGENCY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Necessário para o cliente browser (Supabase Auth no frontend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API /analyze: em produção use sempre JWT (Authorization: Bearer).
# true = aceita userId no body sem JWT (apenas dev/testes locais).
ANALYZE_ALLOW_BODY_USER_ID=false

# Resend
RESEND_API_KEY=
RESEND_FROM=noreply@klarivy.com

# Admin
ADMIN_SECRET=
ADMIN_EMAIL=

# Crons na Vercel: define o mesmo valor em Project Settings → Environment Variables
# como `CRON_SECRET`; a Vercel envia `Authorization: Bearer <CRON_SECRET>` nas invocações.
# Em local, podes omitir e usar só `ADMIN_SECRET` nos curls manuais.
CRON_SECRET=

# App (produção: https://www.klarivy.com)
NEXT_PUBLIC_URL=http://localhost:3000

# Modo manutenção (Vercel): "true" = site mostra /maintenance; APIs (exceto /api/webhook) → 503 JSON.
# Remove ou define como false para voltar ao ar.
MAINTENANCE_MODE=false